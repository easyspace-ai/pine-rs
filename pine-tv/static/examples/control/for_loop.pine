//@version=6
indicator("Control - For Loop", overlay=true)

// Simple for loop with inclusive range
sum = 0.0
for i = 0 to 5
    sum := sum + i

// For loop for rolling calculation
rollingSum = 0.0
count = 0
for i = 0 to 9
    if not na(close[i])
        rollingSum := rollingSum + close[i]
        count := count + 1
avg = count > 0 ? rollingSum / count : na

// For loop with step (not directly supported, use manual increment)
stepSum = 0.0
for i = 0 to 10
    if i % 2 == 0
        stepSum := stepSum + i

plot(avg, title="For Loop Avg 10", color=#2196F3, linewidth=2)
plot(sum, title="Sum 0-5", color=#4CAF50)
