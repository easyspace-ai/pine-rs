//@version=6
indicator("For Loop Variants Test")

// Test 1: For loop with step
sum_by2 = 0.0
for i = 0 to 10 by 2
    sum_by2 := sum_by2 + i
// Expected: 0+2+4+6+8+10 = 30

// Test 2: Nested for loop
sum_nested = 0.0
for i = 1 to 3
    for j = 1 to 2
        sum_nested := sum_nested + i * j
// Expected: 1*1+1*2+2*1+2*2+3*1+3*2 = 1+2+2+4+3+6 = 18

plot(sum_by2, title="Step Sum")
plot(sum_nested, title="Nested Sum")
