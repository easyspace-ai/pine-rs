//@version=6
indicator("Switch Statement Test", overlay=true)

// Test switch with integer values
var result = 0

switch bar_index % 5
    0:
        result := 10
    1:
        result := 20
    2:
        result := 30
    default:
        result := 99

// Test switch with string values
var colorResult = color.blue

switch barstate.isnew
    true:
        colorResult := color.green
    false:
        colorResult := color.red

// Plot results
plot(result, "Switch Result", color=colorResult, linewidth=2)
plotchar(result, "Result Value", location=location.top, color=color.blue)
