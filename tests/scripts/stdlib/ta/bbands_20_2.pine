// Golden test: ta.bb(close, 20, 2)
// Bollinger Bands with length 20 and multiplier 2

indicator("Bollinger Bands Golden Test", overlay=true)

[basis, upper, lower] = ta.bb(close, 20, 2)

plot(basis, title="Basis (SMA 20)", color=color.orange)
plot(upper, title="Upper Band", color=color.blue)
plot(lower, title="Lower Band", color=color.blue)
