//@version=6
indicator("Basic Map Test", overlay=true)

// Create a map
var config = map.new()

// Initialize map on first bar (bar_index 0)
if bar_index == 0
    config := map.put(config, "symbol", "BTCUSDT")
    config := map.put(config, "timeframe", "1h")
    config := map.put(config, "length", 14)
    config := map.put(config, "enabled", true)

// Get values from map
symbol = map.get(config, "symbol")
timeframe = map.get(config, "timeframe")
length = map.get(config, "length")
enabled = map.get(config, "enabled")

// Check if key exists
hasSymbol = map.contains(config, "symbol")
hasMissing = map.contains(config, "missing_key")

// Get map size
mapSize = map.size(config)

// Update map on bar_index 1
if bar_index == 1
    config := map.put(config, "updated", true)
    config := map.remove(config, "enabled")

// Test map.keys and map.values
var keys = array.new_string(0)
var values = array.new_int(0)
if bar_index == 1
    keys := map.keys(config)
    // values := map.values(config)

// Test map.is_empty
isEmpty = map.is_empty(config)

// Plot some results
plot(mapSize, title="Map Size", color=color.blue, display=display.none)
plot(hasSymbol ? 1.0 : 0.0, title="Has Symbol", display=display.none)
plot(hasMissing ? 1.0 : 0.0, title="Has Missing", display=display.none)
plot(isEmpty ? 1.0 : 0.0, title="Is Empty", display=display.none)
