//@version=6
// Debug order: do all assignments first, then access close[i]
indicator("Debug Order 3", shorttitle="DebugOrder3", overlay=true)

floatCount = 0.0
sum = 0.0
intCount = 0
temp = 0.0

for i = 0 to 4
    // First do all increments
    intCount := intCount + 1
    floatCount := floatCount + 1.0
    // Then access close[i] and add to sum
    temp := close[i]
    sum := sum + temp

plot(intCount, title="intCount", color=color.red, display=display.none)
plot(floatCount, title="floatCount", color=color.green, display=display.none)
plot(sum, title="sum", color=color.blue, display=display.none)
