//@version=6
// Debug k vs i as loop variable names
indicator("Debug k vs i", shorttitle="DebugKvI", overlay=true)

// First use k as the loop variable
x = 0.0
for k = 0 to 4
    dummy = close[k]
    x := x + 1.0

// Now use i as the loop variable
y = 0.0
for i = 0 to 4
    dummy = close[i]
    y := y + 1.0

plot(x, title="x (k loop)", color=color.red, display=display.none)
plot(y, title="y (i loop)", color=color.green, display=display.none)
