//@version=6
// Debug script to see what's happening with variables in loops
indicator("Debug Loop Vars", shorttitle="DebugLoopVars", overlay=true)

// Test 1: Store i in a temp var first
testVal1 = 0.0
for i = 0 to 1
    temp = i
    if temp == 0
        testVal1 := testVal1 + 1.0

plot(testVal1, title="testVal1", color=color.red, display=display.none)

// Test 2: Try to get close[i] but log what i is
testVal2 = 0.0
iVal0 = na
iVal1 = na
for i = 0 to 1
    if i == 0
        iVal0 := i
        testVal2 := testVal2 + close[i]
    if i == 1
        iVal1 := i
        testVal2 := testVal2 + close[i]

plot(testVal2, title="testVal2", color=color.green, display=display.none)
plot(iVal0, title="iVal0", color=color.blue, display=display.none)
plot(iVal1, title="iVal1", color=color.purple, display=display.none)

// Also plot close
plot(close, title="close", color=color.gray)
