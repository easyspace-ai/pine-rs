//@version=6
// Debug int vs float increment
indicator("Debug Int vs Float", shorttitle="DebugIntFloat", overlay=true)

// Test both int and float counters
intCount = 0
floatCount = 0.0
sum = 0.0

for i = 0 to 4
    intCount := intCount + 1
    floatCount := floatCount + 1.0
    sum := sum + close[i]

plot(intCount, title="intCount", color=color.red, display=display.none)
plot(floatCount, title="floatCount", color=color.green, display=display.none)
plot(sum, title="sum", color=color.blue, display=display.none)
