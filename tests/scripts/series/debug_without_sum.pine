//@version=6
// Debug without sum := sum + close[i]
indicator("Debug Without Sum", shorttitle="DebugWithoutSum", overlay=true)

intCount = 0
floatCount = 0.0

for i = 0 to 4
    intCount := intCount + 1
    floatCount := floatCount + 1.0
    // Just access close[i] but don't assign to sum
    dummy = close[i]

plot(intCount, title="intCount", color=color.red, display=display.none)
plot(floatCount, title="floatCount", color=color.green, display=display.none)
