//@version=6
// Manual SMA implementation for testing core series functionality
// This script calculates SMA manually without using ta.sma()
indicator("Manual SMA Test", shorttitle="SMA Manual", overlay=true)

length = input.int(5, minval=1, title="SMA Length")

// Manual SMA calculation using historical access.
// Keep output as na until the full warmup window is available.
sum = 0.0
count = 0
for i = 0 to length - 1
    if not na(close[i])
        sum := sum + close[i]
        count := count + 1

manualSma = count == length ? sum / count : na

// Plot the manual SMA
plot(manualSma, title="Manual SMA", color=color.blue, linewidth=2)
plot(close, title="Close", color=color.gray, style=plot.style_line)

// Output for verification
plot(manualSma, title="Output", display=display.none)
