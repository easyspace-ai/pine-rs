//@version=6
// Debug loop i values
indicator("Debug i Values", shorttitle="DebugI", overlay=true)

// Let's try without accessing close[i] first
x1 = 0
for i = 0 to 4
    x1 := x1 + 1

// Now with accessing close[i] but also check what happens
x2 = 0
caughtError = false
for i = 0 to 4
    // Let's separate out each step
    x2 := x2 + 1
    // Let's not access close[i] for now to see if x2 becomes 5

plot(x1, title="x1", color=color.red, display=display.none)
plot(x2, title="x2", color=color.green, display=display.none)
