//@version=6
// Debug script to see what's happening in the for loop
indicator("Debug Loop", shorttitle="DebugLoop", overlay=true)

length = input.int(5, minval=1, title="SMA Length")

// Let's trace what happens in the loop
sum = 0.0
count = 0

// First test: can we access the loop variable?
test_i0 = 0
test_i1 = 1

val0 = close[test_i0]
val1 = close[test_i1]

plot(val0, title="val0", color=color.red, display=display.none)
plot(val1, title="val1", color=color.green, display=display.none)

// Now try with a loop - let's do a simpler version first
// Let's just try to add 1+1 in the loop to see if the loop runs at all
loopSum = 0.0
for i = 0 to 1
    loopSum := loopSum + 1.0

plot(loopSum, title="loopSum", color=color.blue, display=display.none)

// Now try accessing close in the loop
loopCloseSum = 0.0
for i = 0 to 1
    if not na(close[i])
        loopCloseSum := loopCloseSum + close[i]

plot(loopCloseSum, title="loopCloseSum", color=color.purple, display=display.none)

// Also plot close
plot(close, title="close", color=color.gray)
